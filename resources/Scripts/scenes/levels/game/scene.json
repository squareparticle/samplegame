{
  "globals": {
    "$contentBounds": { "value": { "x": 0, "y": 0, "width": 1280, "height": 720 } },
    "$screenPercent": { "value": { "x": 0, "y": 0, "width": 1, "height": 1 } },
    "$mapFile": { "value": "scenes/levels/game/map" },
    "$hudFile": { "value": "scenes/levels/game/hudLayout" }
  },

  "entities": {
    "Player": { "scriptResource": "entities/player" },
    "Debris": { "scriptResource": "entities/debris" },
    "Pulse": { "scriptResource": "entities/pulse" },
    "DebrisSpawner": { "scriptResource": "entities/debris-spawner" },
    "Gem": { "scriptResource": "entities/gem" }
  },

  "groups": [
    { "objectGroups": [ "debris", "projectiles", "collectibles", "hud" ], "data": [] },
    { "objectGroups": [ "gameObjects", "playerObject", "input" ], "load":"inputObjects", "scriptResource": "{$mapFile}" },
    { "objectGroups": [ "gameObjects" ], "load":"interactables", "scriptResource": "{$mapFile}" },
    { "widgetGroups": [ "GUIWidgets" ], "load": "widgets", "scriptResource": "{$hudFile}" }    
  ],

  "layers": [
    {
      "base": { "type": "CreateCanvasLayer", "id": "ContentCanvas" },
      "properties": { "sizeFromBounds": "{$contentBounds}", "imageSmoothingEnabled": true }
    },
    {
      "base": { "type": "ObjectLayer", "id": "ObjectLayer" },
      "properties": {
        "source": "ContentCanvas",
        "layerGroups": [ "debris", "gameObjects", "collectibles", "projectiles", "hud" ]
      }
    },
    {
      "base": { "type": "PasteToCanvasLayer", "id": "ScaleToScreen" },
      "properties": {
        "source": "ContentCanvas", "dest": "gameCanvas",
        "destBounds_MatchCanvas": "{$screenPercent}",
        "options": { "respectAspectRatio": true }
      }
    },
    {
      "base": { "type": "GUILayer", "id": "GUILayer" },
      "properties": {
        "source": "gameCanvas",
        "layoutScript": { "layerGroups": [ "GUIWidgets" ] },
        "options": { "reBounds": "{$contentBounds}", "respectAspectRatio": true }
      }
    }    
  ]
}
