{
  "type": "GameObject",
  "name": "DebrisSpawner",
  "globals": {},
  "components": [
    {
      "type": "TransformComponent",
      "base": { "id": "Transform" },
      "properties": { "position": { "x": 0, "y": 0 }, "scale": { "x": 1, "y": 1 }, "rotation": { "angle": 0 } }
    },
    
    {
    "type": "EntitySpawnerComponent",
    "base": { "id": "DebrisSpawner", "requires": ["Transform"] },
    "properties": {
        "entity": "Debris",
        "groups": ["debris", "gameObjects"],
        "spawnMode": "once",
        "count": 6,

        "spawnArea": {
            "space": "world",
            "rectangle": {
                "origin": "topLeft",
                "width": 1280,
                "height": 720,
                "padding": 90
            }
        },

        "minDistanceFromTransform": 0,
        "minDistanceFromGroupEntities": 180,
        "avoidGroups": ["playerObject"],

        "randomRotation": true,
        "scale": 0.11,
        "velocity": {
            "speed": { "min": 30, "max": 90 },
            "direction": "random"
        },
        "torque": { "min": -30, "max": 30 }
        }
    }
  ]
}
