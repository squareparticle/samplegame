{
  "type": "GameObject",
  "name": "DebrisSpawner",
  "globals": {
    "position": { "@loadingRule": { "this": "spawnPosition" } },
    "rotation": { "@range": { "min": 0, "max": 6.283185307179586 } }    
  },
  "components": [
    {
      "type": "TransformComponent",
      "base": { "id": "Transform" },
      "properties": { "position": { "x": 0, "y": 0 }, "scale": { "x": 1, "y": 1 }, "rotation": { "angle": 0 } }
    },
    
    {
        "type": "EntitySpawnerComponent",
        "base": { "id": "DebrisSpawner", "requires": ["Transform"] },
        "properties": {
            "spawnArea": {
                "space": "world",
                "rectangle": { "origin": "topLeft", "width": 1280, "height": 720, "padding": 90 }
            },

            "dynamic": {
                "count": 10,
                "burstCount": 2,
                "interval": 3,
                "onDestroy": "detach"
            },

            "entities": [
                {
                    "label": "Small Debris",
                    "weight": 4,
                    "groups": ["debris", "gameObjects"],
                    "Object": {
                        "entity": "Debris",
                        "load": {
                            "position": "{$position}",
                            "scale": {
                                "x": { "@range": { "min": 0.07, "max": 0.10 } },
                                "y": { "@range": { "min": 0.07, "max": 0.10 } }
                            },
                            "rotation": "{$rotation}",
                            "velocity": {
                                "x": { "@range": { "min": -120, "max": 120 } },
                                "y": { "@range": { "min": -120, "max": 120 } }
                            },
                            "HP": 1,
                            "points": 100
                        }
                    }
                },
                {
                    "label": "Large Debris",
                    "weight": 1,
                    "groups": ["debris", "gameObjects"],
                    "Object": {
                        "entity": "Debris",
                        "load": {
                            "position": "{$position}",
                            "scale": {
                                "x": { "@range": { "min": 0.14, "max": 0.18 } },
                                "y": { "@range": { "min": 0.14, "max": 0.18 } }
                            },
                            "rotation": "{$rotation}",
                            "velocity": {
                                "x": { "@range": { "min": -45, "max": 45 } },
                                "y": { "@range": { "min": -45, "max": 45 } }
                            },
                            "HP": 2,
                            "points": 200
                        },
                        "update": {
                            "component": {
                                "#Motion": {
                                    "options.torque": { "@range": { "min": -30, "max": 30 } }
                                }
                            }
                        }
                    }
                }
            ],

            "minDistanceFromTransform": 0,
            "minDistanceFromGroupEntities": 180,
            "avoidGroups": ["playerObject"]
        }
    }]
}
