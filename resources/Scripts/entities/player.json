{
  "type": "GameObject",
  "name": "Player",
  "globals": {},
  "components": [
    {
      "type": "StandardActionController", "base": { "id": "Motion", "channels": [ "Motion" ], "requires": [ "Transform" ] },
      "properties": { "speed": { "rate": 260 }, "angular": { "speed": { "rate": 3 } }, "direction": { "x": 0, "y": 0 } }
    },
    {
      "type": "TransformComponent", "base": { "id": "Transform" },
      "properties": { "position": { "x": 0, "y": 0 }, "scale": { "x": 0.035, "y": 0.035 }, "rotation": { "angle": 0 } }
    },
    {
      "type": "ImageComponent", "base": { "id": "Image", "requires": [ "Transform" ] },
      "properties": { "imageResource": "salvage-ship.png" }
    },
    {
      "type": "InputActionBroadcaster", "base": { "id": "InputActionBroadcaster" },
      "properties": {
        "Motion": [ "MOVE_FORWARD", "ROTATE_COUNTERCLOCKWISE", "ROTATE_CLOCKWISE", "IDLE" ],
        "Weapons": [ "ACTION_1" ]
      }
    },
    {
        "type": "ColliderComponent", "base": { "id": "BlockCollider", "requires": ["Transform", "Image"] },
        "properties": { "renderer":{"boundingCalculation": "performance", "colliderType": "sprite"}, "shape":"circle", "rscale":0.8 }
    },    
    {
      "type": "FirePulseComponent", "base": { "id": "PulseWeapon", "channels": [ "Weapons" ], "requires": [ "Transform" ] },
      "properties": {
        "projectileEntity": "Pulse",
        "projectileGroup": "projectiles",
        "cooldown": 0.25,
        "spawnDistance": 52
      }
    },
    {
      "type": "ScreenWrapComponent", "base": { "id": "ScreenWrap", "requires": [ "Transform" ] },
      "properties": {
        "bounds": { "x": 0, "y": 0, "width": 1280, "height": 720 },
        "margin": 50
      }
    }
  ]
}
