{
  "type": "GameObject",
  "name": "Debris",
  "globals": {},
  "components": [
    {
      "type": "TransformComponent",
      "base": { "id": "Transform" },
      "properties": { "position": { "x": 0, "y": 0 }, "scale": { "x": 0.11, "y": 0.11 }, "rotation": { "angle": 0 } }
    },
    {
      "type": "BasicPhysicsListener",
      "base": { "id": "Motion", "requires": [ "Transform" ] }, 
      "properties": { "isDynamic": true }
    },
    {
      "type": "ImageComponent",
      "base": { "id": "Image", "requires": [ "Transform" ] },
      "properties": { "imageResource": "debris.png" }
    },
    {
      "type": "ScreenWrapComponent",
      "base": { "id": "ScreenWrap", "requires": [ "Transform" ] },
      "properties": { "bounds": { "x": 0, "y": 0, "width": 1280, "height": 720 }, "margin": 80 }
    },
    {
      "type": "LoadComponent",
      "base": { "id": "Load" },
      "properties": { "editors":[
          {"update": {
              "#Transform": {
                  "options.position": "$position",
                  "options.scale": "$scale",
                  "options.rotation.angle": "$rotation"
              },
              "#Motion": {
                  "options.velocity": "$velocity"
              }
          }}
      ]}
    }
  ]
}
