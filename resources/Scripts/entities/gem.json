{
  "type": "GameObject",
  "name": "Gem",
  "globals": {},
  "components": [
    { 
      "type": "TransformComponent", "base": { "id": "Transform" },
      "properties": { "position": { "x": 0, "y": 0 }, "scale": { "x": 0.42, "y": 0.42 }, "rotation": { "angle": 0 } }
    },
    {
      "type": "BasicPhysicsListener",
      "base": { "id": "Motion", "requires": [ "Transform" ] },
      "properties": { "isDynamic": true, "velocity": { "x": 0, "y": 0 }, "torque": 20 }
    },
    {
      "type": "ImageComponent",
      "base": { "id": "Image", "requires": [ "Transform" ] },
      "properties": { "imageResource": "gem.png" }
    },
    {
      "type": "TTLComponent", "base": { "id": "TTL" },
      "properties": { "TTL": 4000 }
    },    
    {
        "type": "ColliderComponent", "base": { "id": "BlockCollider", "requires": ["Transform", "Image"] },
        "properties": { "renderer":{"boundingCalculation": "performance", "colliderType": "image"}, "shape":"circle", "rscale":0.5 }
    },
    {
      "type": "TriggerDetectorComponent",
      "base": { "id": "CollectDetector", "requires": ["BlockCollider"] },
      "properties": { "detectGroups": ["playerObject"], "otherColliderID": "BlockCollider",
        "@RUN": {
          "+onEnter":[
            {"@SCENE":{"addCollectable":{}}},
            {"@SELFOBJECT":{"destroy":{}}}
          ]
        }
      }
    }
  ]
}
